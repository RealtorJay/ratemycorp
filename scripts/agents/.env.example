# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API (required) — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Congress.gov API (required for Congress agent) — get from api.congress.gov/sign-up
CONGRESS_GOV_API_KEY=your-key

# FEC API (required for Connections agent) — get from api.open.fec.gov/developers
FEC_API_KEY=your-key

# Google Custom Search (required for Promise Tracker + Company News agents)
# Set up at programmablesearchengine.google.com
GOOGLE_SEARCH_API_KEY=your-key
GOOGLE_SEARCH_CX=your-search-engine-id
